{
  "expo": {
    "name": "Gymvy",
    "slug": "gymapp",
    "version": "1.8.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "gymvy",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "jsEngine": "jsc",
    "ios": {
      "bundleIdentifier": "com.ryanasar.gymapp",
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "This app requires access to your camera to take photos for your workout posts.",
        "NSPhotoLibraryUsageDescription": "This app requires access to your photo library to select photos for your workout posts.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",

        "android.permission.POST_NOTIFICATIONS"
      ],
      "package": "com.ryanasar.gymvy"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-dev-client",
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo-transparent.png",
          "imageWidth": 150,
          "resizeMode": "contain",
          "backgroundColor": "#F1F5F9",
          "dark": {
            "image": "./assets/images/logo-transparent.png",
            "imageWidth": 150,
            "resizeMode": "contain",
            "backgroundColor": "#0A0A0F"
          }
        }
      ],
      "expo-secure-store",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "This app requires access to your photo library to select photos for your workout posts.",
          "cameraPermission": "This app requires access to your camera to take photos for your workout posts."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#ffffff"
        }
      ],
      "expo-apple-authentication"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "privacyPolicyUrl": "https://ryanasar.github.io/gymvy-site/privacy.html",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1a23bb04-c242-430a-af8d-f2a4e02a82fc"
      }
    }
  }
}
